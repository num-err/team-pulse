# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# App
APP_ENV=development
# API key — leave empty to skip auth in dev
# Generate: python -c "import secrets; print('tpulse_' + secrets.token_urlsafe(32))"
API_KEY=

# GitHub webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Linear webhook
LINEAR_WEBHOOK_SECRET=your-linear-signing-secret

# Figma webhook
FIGMA_WEBHOOK_PASSCODE=choose-any-secret-string

# Notion
NOTION_TOKEN=secret_your-notion-integration-token

# Anthropic
ANTHROPIC_API_KEY=

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_DEFAULT_CHANNEL=#standup

# Scheduler (24h clock, UTC)
DIGEST_CRON_HOUR=9
DIGEST_CRON_MINUTE=0
